# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/fintech_wallet

# Redis (used for idempotency key cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# If you do NOT have Redis installed locally, set this to "true" and the
# server will automatically fall back to a safe in-memory idempotency cache.
# This is intended for local development only — use real Redis in production
# so idempotency keys survive restarts and work across multiple server instances.
USE_IN_MEMORY_CACHE=true

# JWT
ACCESS_TOKEN_SECRET=replace_this_with_a_long_random_access_secret_value
REFRESH_TOKEN_SECRET=replace_this_with_a_long_random_refresh_secret_value
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
